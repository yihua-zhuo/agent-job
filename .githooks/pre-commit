#!/bin/bash
# Pre-commit hook: run ruff lint + format checks before commit (non-blocking)

set -e

echo "Running pre-commit checks..."

cd "$(git rev-parse --show-toplevel)"

# Run ruff check (only if installed)
if python3 -m ruff version &>/dev/null 2>&1; then
    echo "=== ruff check ==="
    python3 -m ruff check src/ || true
    echo "=== ruff format ==="
    python3 -m ruff format --check src/ || true
else
    echo "ruff not found, skipping"
fi

# Run mypy (only if installed)
if python3 -m mypy --version &>/dev/null 2>&1; then
    echo "=== mypy ==="
    python3 -m mypy src/ --ignore-missing-imports --no-error-summary 2>&1 | grep -E "^src/.*error:" || true
else
    echo "mypy not found, skipping"
fi

echo "Pre-commit checks complete"

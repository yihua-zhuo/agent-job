#!/bin/bash
# Pre-commit hook: run lint checks before commit (non-blocking)

set -e

echo "🔍 Running pre-commit lint checks..."

cd "$(git rev-parse --show-toplevel)"

FLAKE8="python3 -m flake8"
MYPY="python3 -m mypy"

# Run flake8 (only if installed)
if [ -x "$FLAKE8" ]; then
    echo "=== flake8 ==="
    $FLAKE8 src/ --count --select=E9,F63,F7,F82 --show-source --statistics || true
else
    echo "⚠️  flake8 not found, skipping"
fi

# Run mypy (only if installed)
if $MYPY --version &>/dev/null 2>&1; then
    echo "=== mypy ==="
    $MYPY src/ --ignore-missing-imports --no-error-summary 2>&1 | grep -E "^src/.*error:" || true
else
    echo "⚠️  mypy not found, skipping"
fi

echo "✅ Pre-commit lint checks complete"
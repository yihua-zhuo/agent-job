#!/bin/bash
# Pre-push hook: run lint checks before push (non-blocking - warnings only)

set -e

echo "🔍 Running pre-push lint checks..."

cd "$(git rev-parse --show-toplevel)"

FLAKE8="/home/node/.local/bin/flake8"
MYPY="python3 -m mypy"

# Run flake8 - show critical errors
echo "=== flake8 ==="
if [ -x "$FLAKE8" ]; then
    $FLAKE8 src/ --count --select=E9,F63,F7,F82 --show-source --statistics || true
else
    echo "⚠️  flake8 not found, skipping"
fi
echo "✅ flake8 check done"

# Run mypy - non-blocking, show type errors as warnings
echo "=== mypy ==="
if $MYPY --version &>/dev/null 2>&1; then
    $MYPY src/ --ignore-missing-imports --no-error-summary 2>&1 | grep -E "^src/.*error:" || true
else
    echo "⚠️  mypy not found, skipping"
fi
echo "✅ mypy check done"

echo "✅ Pre-push lint checks complete"
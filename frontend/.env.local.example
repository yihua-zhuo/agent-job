# Backend API base URL.
# In development, this proxies /api/* → http://localhost:8000 via next.config.ts rewrites.
# In production, the rewrite in next.config.ts handles routing automatically.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000

# 32-character hex string used for client-side obfuscation of auth tokens stored in localStorage.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
NEXT_PUBLIC_AUTH_KEY=0123456789abcdef0123456789abcdef

{
  "module": "RBAC权限认证模块",
  "implemented_at": "2026-04-12T09:42:00Z",
  "features": [
    {
      "file": "src/middleware/auth.py",
      "description": "认证中间件",
      "components": [
        "AuthMiddleware类 - JWT认证中间件",
        "verify_token() - 验证JWT token并返回payload",
        "require_auth装饰器 - 需要认证的API端点保护",
        "require_role装饰器 - 基于角色的访问控制装饰器"
      ]
    },
    {
      "file": "src/services/auth_service.py",
      "description": "认证服务",
      "components": [
        "AuthService类 - JWT认证服务",
        "generate_token() - 生成24小时有效期的JWT token",
        "verify_token() - 验证token并返回payload",
        "refresh_token() - 刷新过期token"
      ]
    },
    {
      "file": "src/services/rbac_service.py",
      "description": "权限服务",
      "components": [
        "Permission枚举 - 定义所有权限（客户、销售、管理员）",
        "RBACService类 - 角色权限映射服务",
        "ROLE_PERMISSIONS - 角色权限映射表",
        "has_permission() - 检查角色是否拥有指定权限",
        "get_role_permissions() - 获取角色的所有权限",
        "check_permission_by_value() - 通过权限字符串值检查权限"
      ]
    },
    {
      "file": "src/models/user.py",
      "description": "用户模型扩展",
      "components": [
        "Role枚举 - 定义系统角色（ADMIN, MANAGER, SALES, SUPPORT, VIEWER）"
      ]
    }
  ],
  "roles": [
    "admin - 拥有所有权限",
    "manager - 读取权限 + 创建/更新销售机会",
    "sales - 客户读取/创建/更新 + 销售机会读取/创建/更新",
    "support - 仅读取客户和销售机会",
    "viewer - 仅读取客户和销售机会"
  ],
  "permissions": [
    "customer:create - 创建客户",
    "customer:read - 读取客户",
    "customer:update - 更新客户",
    "customer:delete - 删除客户",
    "opportunity:create - 创建销售机会",
    "opportunity:read - 读取销售机会",
    "opportunity:update - 更新销售机会",
    "opportunity:delete - 删除销售机会",
    "admin:all - 管理员所有权限",
    "user:manage - 用户管理权限"
  ]
}
